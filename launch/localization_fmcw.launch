<launch>
    <arg name="rviz" default="true" />
    <arg name="map_path" default="/home/amov/ws_FASTLIO_KFY/helmet_pdr_S1_stair_2026_05_12_B4_B3/12834 - Block S1_voxel_0p10.pcd" />

    <rosparam command="load" file="$(find fast_lio)/config/fmcw_goodimu.yaml" />

    <param name="feature_extract_enable" type="bool" value="0"/>
    <param name="point_filter_num" type="int" value="1"/>
    <param name="max_iteration" type="int" value="20" />
    <param name="filter_size_surf" type="double" value="0.3" />
    <param name="filter_size_map" type="double" value="0.3" />
    <param name="cube_side_length" type="double" value="1000" />
    <param name="runtime_pos_log_enable" type="bool" value="0" />
    <param name="map_path" type="string" value="$(arg map_path)" />

    <group if="$(arg rviz)">
        <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find fast_lio)/rviz_cfg/localization.rviz"/>
    </group>

    <node pkg="fast_lio" type="fastlio_localization" name="fastlio_localization" output="screen" />

    <!-- Single-bag + fixed-map usage: keep auto relocalization off for stability. -->
    <!-- <node pkg="fast_lio" type="relocalization_handler.py" name="relocalization_handler" output="screen"/> -->
</launch>
